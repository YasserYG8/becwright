{
  "name": "becwright",
  "version": "0.4.0",
  "description": "The enforcement layer for AI coding agents — deterministic, portable constraints (BECs) that block a commit when a rule breaks, for AI-written and human-written code. No Python required.",
  "bin": {
    "becwright": "bin/becwright.js"
  },
  "files": [
    "bin/"
  ],
  "keywords": [
    "git-hooks",
    "pre-commit",
    "lint",
    "linter",
    "code-quality",
    "code-review",
    "static-analysis",
    "constraints",
    "ai-agents",
    "claude-code",
    "developer-tools",
    "bec"
  ],
  "homepage": "https://github.com/DataDave-Dev/becwright",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DataDave-Dev/becwright.git"
  },
  "license": "MIT",
  "engines": {
    "node": ">=16"
  },
  "optionalDependencies": {
    "@becwright/linux-x64": "0.3.0",
    "@becwright/linux-arm64": "0.3.0",
    "@becwright/darwin-x64": "0.3.0",
    "@becwright/darwin-arm64": "0.3.0",
    "@becwright/win32-x64": "0.3.0"
  }
}
